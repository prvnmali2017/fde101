# OpenAI API key (required unless MOCK_LLM=true)
OPENAI_API_KEY=

# Use mock responses without calling an LLM (good for offline demo)
MOCK_LLM=true

# Model selection
OPENAI_MODEL=gpt-4o-mini

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# API settings
API_HOST=0.0.0.0
API_PORT=8000
